# CashFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your keys

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Use a server-side key. Prefer service role only when absolutely required.
SUPABASE_KEY=your_server_side_supabase_key

# ── Groq (AI Categorization + Chat) ───────────────────────────────────────────
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── OCR.space (Receipt Parsing) ────────────────────────────────────────────────
# Free tier at: https://ocr.space/ocrapi (register → get key)
OCR_SPACE_API_KEY=your_ocr_space_key_here

# ── App Config ─────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000

# ── API Security ───────────────────────────────────────────────────────────────
# Set AUTH_REQUIRED=true in production
AUTH_REQUIRED=true
# Send this value via `X-API-Key` or `Authorization: Bearer <key>`
API_KEY=change_this_to_a_long_random_secret
# Max upload size in MB
MAX_UPLOAD_MB=10
