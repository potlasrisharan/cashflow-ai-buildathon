# CashFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your keys

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Groq (AI Categorization + Chat) ───────────────────────────────────────────
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── OCR.space (Receipt Parsing) ────────────────────────────────────────────────
# Free tier at: https://ocr.space/ocrapi (register → get key)
OCR_SPACE_API_KEY=your_ocr_space_key_here

# ── App Config ─────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000
